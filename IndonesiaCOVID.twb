      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0ezrw3i0km54wp1fplhhp18pabxi].[avg:Case Fatality Rate:qk]&quot;' value='Case Fatality Rate' />
          <alias key='&quot;[federated.0ezrw3i0km54wp1fplhhp18pabxi].[max:Total Cases:qk]&quot;' value='Total Cases' />
          <alias key='&quot;[federated.0ezrw3i0km54wp1fplhhp18pabxi].[max:Total Deaths:qk]&quot;' value='Total Deaths' />
          <alias key='&quot;[federated.0ezrw3i0km54wp1fplhhp18pabxi].[max:Total Recovered:qk]&quot;' value='Total Recovered' />
        </aliases>
      </column>
      <column caption='Dynamic Header' datatype='string' name='[Calculation_0123148857167872]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF COUNTD([Province]) &gt; 1 THEN &quot;Indonesia Overview&quot; &#13;&#10;ELSE ATTR([Province]) + &quot; Overview&quot; &#13;&#10;END' />
      </column>
      <column caption='CFR' datatype='real' name='[Calculation_0337003582398464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Total Deaths]) / MAX([Total Cases])' />
      </column>
      <column caption='Recovery Rate' datatype='real' name='[Calculation_0337003582693377]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Total Recovered]) / MAX([Total Cases])' />
      </column>
      <column caption='Active Burden Ratio' datatype='real' name='[Calculation_0337003582816258]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(MAX([Total Cases]) - MAX([Total Deaths]) - MAX([Total Recovered]))&#13;&#10;/ MAX([Total Cases])' />
      </column>
      <column caption='7-Day Rolling Avg Cases' datatype='real' name='[Calculation_0337003586711555]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([New Cases]), -6, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='7-Day Rolling Avg Deaths' datatype='real' name='[Calculation_0337003586764804]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([New Deaths]), -6, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Normalized Case Intensity' datatype='real' name='[Calculation_0337003601723398]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([New Cases]) / WINDOW_MAX(SUM([New Cases]), &#13;&#10;  FIRST(), LAST())'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Active Cases' datatype='integer' name='[Calculation_0337003607314439]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total Cases] - [Total Deaths] - [Total Recovered]' />
      </column>
      <column caption='Above Avg CFR' datatype='boolean' name='[Calculation_1893087097581569]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0337003582398464] &gt;= WINDOW_AVG([Calculation_0337003582398464])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Above Average Cases Province' datatype='boolean' name='[Calculation_1893087103266818]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAX([Total Cases])&gt;=WINDOW_AVG(MAX([Total Cases]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
